{
  "version": "1.0.0",
  "trigger": "setup",
  "description": "OpenCode Starter Kit - Interactive setup menu",
  
  "agent_instructions": "MANDATORY: When user types 'setup': 1) Run check-question-tool.sh 2) Read this file 3) Use question tool for ALL user choices 4) Follow flow: presets → confirm/customize → categories → dispatch. NEVER skip the question tool.",
  
  "presets": {
    "full": {
      "label": "Full Install (Recommended)",
      "description": "Everything included - complete setup (~10 min)",
      "includes": ["*"],
      "is_default": true
    },
    "recommended": {
      "label": "Recommended",
      "description": "Core + skills + essential containers (~5 min)",
      "includes": ["agents-config", "skill-factory", "brainstorming", "openmemory-lite", "tracking-system", "cron", "reminder", "blog-post-creator", "transcription", "memory-skill", "tracking-skill", "docker-base", "portainer", "homepage"]
    },
    "minimal": {
      "label": "Minimal",
      "description": "AGENTS config + skill factory + memory only (~2 min)",
      "includes": ["agents-config", "skill-factory", "openmemory-lite"]
    },
    "custom": {
      "label": "Custom",
      "description": "Pick individual components",
      "includes": [],
      "skip_to": "categories"
    }
  },
  
  "categories": [
    {
      "id": "core",
      "label": "Core Systems",
      "description": "Essential infrastructure",
      "options": [
        {"id": "agents-config", "label": "AGENTS.md Config (Recommended)", "description": "Agent behavior and trigger commands"},
        {"id": "skill-factory", "label": "Skill Factory", "description": "Meta-skill for skill creation", "required_for": ["recommended", "full"]},
        {"id": "menu-factory", "label": "Menu Factory", "description": "Standardize and validate skill menus", "requires": ["menu-learning"]},
        {"id": "menu-learning", "label": "Menu Learning", "description": "Adaptive menus that learn from choices"},
        {"id": "openmemory-lite", "label": "Memory - OpenMemory Lite", "description": "Persistent memory with conversations, reminders, dashboard", "requires": ["docker-base"]},
        {"id": "memory-json", "label": "Memory - JSON File", "description": "Simple file-based memory, no Docker required"},
        {"id": "tracking-system", "label": "Tracking", "description": "Flow and context tracking"},
        {"id": "opentelemetry", "label": "OpenTelemetry", "description": "Observability and tracing", "requires": ["docker-base"]}
      ]
    },
    {
      "id": "skills",
      "label": "Skills",
      "description": "Pre-built skills for common tasks",
      "options": [
        {"id": "brainstorming", "label": "Brainstorming (Recommended)", "description": "Design exploration - use before creative work"},
        {"id": "cron", "label": "Cron", "description": "Scheduled task management"},
        {"id": "reminder", "label": "Reminder", "description": "Telegram reminders with cron"},
        {"id": "blog-post-creator", "label": "Blog Post Creator", "description": "Hugo blog workflow with YouTube pipeline"},
        {"id": "transcription", "label": "YouTube Transcription", "description": "Extract transcripts, auto-create blog posts", "requires": ["blog-post-creator"]},
        {"id": "memory-skill", "label": "Memory Gateway", "description": "Memory skill interface (trigger: mem)", "requires": ["openmemory-lite"]},
        {"id": "tracking-skill", "label": "Tracking Gateway", "description": "Tracking skill interface (trigger: cr)"},
        {"id": "openrag", "label": "OpenRAG", "description": "Document retrieval stack", "requires": ["docker-base"]}
      ]
    },
    {
      "id": "containers",
      "label": "Container Services",
      "description": "Docker-based services",
      "options": [
        {"id": "docker-base", "label": "Docker Compose", "description": "Base container configuration", "required": true},
        {"id": "portainer", "label": "Portainer", "description": "Container management UI (port 9000)", "requires": ["docker-base"]},
        {"id": "homepage", "label": "Homepage", "description": "Server dashboard (port 8765)", "requires": ["docker-base"]},
        {"id": "nextexplorer", "label": "NextExplorer", "description": "File browser (port 8080)", "requires": ["docker-base"]},
        {"id": "usermemos", "label": "UserMemos", "description": "Note-taking app (port 5232)", "requires": ["docker-base"]}
      ]
    }
  ],
  
  "flow": {
    "steps": [
      "1. Run check-question-tool.sh",
      "2. Present presets (Full Install is first option)",
      "3. If Full/Recommended/Minimal selected → confirm → dispatch",
      "4. If Custom → present categories (multi-select)",
      "5. Resolve dependencies",
      "6. Confirm selections",
      "7. Dispatch to build agent"
    ]
  },
  
  "question_tool_examples": {
    "presets": {
      "question": "Welcome to OpenCode Starter Kit! Choose your setup:",
      "header": "Setup",
      "options": [
        {"label": "Full Install (Recommended)", "description": "Everything included - complete AI assistant setup (~10 min)"},
        {"label": "Recommended", "description": "Core + skills + containers (~5 min)"},
        {"label": "Minimal", "description": "Just essentials (~2 min)"},
        {"label": "Custom", "description": "Pick individual components"}
      ],
      "multiple": false
    },
    "categories": {
      "question": "Select components to install:",
      "header": "Components",
      "options": [],
      "multiple": true
    },
    "confirm": {
      "question": "Install selected components?",
      "header": "Confirm",
      "options": [
        {"label": "Yes, proceed (Recommended)", "description": "Start installation"},
        {"label": "Modify", "description": "Change selections"},
        {"label": "Cancel", "description": "Abort setup"}
      ],
      "multiple": false
    }
  },
  
  "dispatch": {
    "type": "subagent",
    "agent": "general",
    "instruction": "Read setup/.selections.json and execute phases in setup/phases/ in order. Update setup/.progress.json after each phase."
  }
}
